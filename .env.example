# Supabase (get values from `supabase status`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend
PORT=3001
ADMIN_PASSWORD=your-admin-password
OWNER_USER_ID=owner-uuid-from-seed
FRONTEND_URL=http://localhost:5173

# Deployment
VERCEL_TOKEN=your-vercel-token
GITHUB_TOKEN=your-github-token
GITHUB_ORG=TheDAIO
GITHUB_DEFAULT_REPO_PRIVATE=true

# Domain Purchase (Porkbun)
PORKBUN_API_KEY=your-porkbun-api-key
PORKBUN_API_SECRET=your-porkbun-api-secret

# Research (Tavily)
TAVILY_API_KEY=your-tavily-api-key

# Distribution (Twitter/X — get credentials at console.x.com)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-twitter-access-token-secret

# Frontend (prefix with VITE_ for Vite)
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key
